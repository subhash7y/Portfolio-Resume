<svg xmlns="http://www.w3.org/2000/svg" width="200" height="200" viewBox="0 0 200 200">
  <!-- Background -->
  <rect width="200" height="200" rx="40" fill="#6C5CE7"/>
  
  <!-- Chart bars for dashboard icon -->
  <rect x="50" y="110" width="15" height="40" fill="#FFFFFF" rx="2"/>
  <rect x="75" y="95" width="15" height="55" fill="#FFFFFF" rx="2"/>
  <rect x="100" y="80" width="15" height="70" fill="#FFFFFF" rx="2"/>
  <rect x="125" y="100" width="15" height="50" fill="#FFFFFF" rx="2"/>
  
  <!-- Title text -->
  <text x="100" y="50" font-family="Arial, sans-serif" font-size="24" font-weight="bold" text-anchor="middle" fill="#FFFFFF">Portfolio</text>
</svg>